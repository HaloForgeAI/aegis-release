# Public Aegis native example.

AEGIS_AUTH_SECRET=
AEGIS_BOOTSTRAP_TENANT=studio-a
AEGIS_PROFILE=release
AEGIS_API_URL=http://localhost:8787
AEGIS_PUBLIC_URL=http://localhost:8788
AEGIS_WEB_PORT=8788
AEGIS_RUNTIME_DIR=.aegis
AEGIS_RUN_DIR=.aegis/run
AEGIS_LOG_DIR=.aegis/logs
AEGIS_EVIDENCE_DIR=.aegis/evidence
AEGIS_SQLITE_PATH=.aegis/db/aegis.sqlite
AEGIS_ATTACHMENTS_DIR=.aegis/attachments

# Optional advanced/cloud backends are not required by the default native bundle.
# AEGIS_PG_URL=
# AEGIS_REDIS_URL=
# AEGIS_S3_ENDPOINT=
# AEGIS_S3_BUCKET=
# AEGIS_S3_ACCESS_KEY=
# AEGIS_S3_SECRET_KEY=

AEGIS_LLM_BASE_URL=
AEGIS_LLM_MODEL=
AEGIS_LLM_API_KEY=

AEGIS_CONTEXT_MAINTENANCE_ENABLED=true
AEGIS_CONTEXT_MAINTENANCE_USE_LLM=false
AEGIS_GATEWAY_DISPATCH_ENABLED=true
AEGIS_GATEWAY_HEALTH_ENABLED=true
AEGIS_AUTOMATION_SCHEDULER_ENABLED=true

AEGIS_TELEGRAM_BOT_TOKEN=
AEGIS_TELEGRAM_TENANT=studio-a
AEGIS_TELEGRAM_MODE=polling
AEGIS_TELEGRAM_SECRET_TOKEN=

# Public Aegis compose example.
# Copy to .env, then replace every generated/secret value locally.

AEGIS_VERSION=v0.1.1
AEGIS_IMAGE=ghcr.io/haloforgeai/aegis:v0.1.1

# Required. Generate with: openssl rand -hex 32
AEGIS_AUTH_SECRET=

# Optional live LLM provider. Leave blank to boot without provider-backed chat.
AEGIS_LLM_BASE_URL=
AEGIS_LLM_MODEL=
AEGIS_LLM_API_KEY=

# Optional channels.
AEGIS_TELEGRAM_BOT_TOKEN=
AEGIS_TELEGRAM_TENANT=
AEGIS_TELEGRAM_MODE=
AEGIS_TELEGRAM_SECRET_TOKEN=

AEGIS_CONTEXT_MAINTENANCE_ENABLED=true
AEGIS_CONTEXT_MAINTENANCE_USE_LLM=false
AEGIS_GATEWAY_DISPATCH_ENABLED=true
AEGIS_GATEWAY_HEALTH_ENABLED=true
AEGIS_AUTOMATION_SCHEDULER_ENABLED=true
AEGIS_AUTOMATION_SCHEDULER_INTERVAL_SECS=60
